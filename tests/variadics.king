fn add_metrics(category: i64, others: f64) -> f64 {
    let mut sum = category as f64;
    inline for i in 0..others.len {
        sum = sum + others[i];
    }
    return sum;
}

fn multiAdd<T: type>(first: &str, others: T) -> i64 {
    let mut sum = 0;
    inline for i in 0..others.len {
        sum = sum + (others[i] as i64);
    }
    return sum;
}

fn main() -> i64 {
    let res1 = add_metrics(10, 1.5, 2.5, 3.5); // 10 + 1.5 + 2.5 + 3.5 = 17.5
    let res2 = multiAdd<i64>("hello", 10, 20, 30); // 10 + 20 + 30 = 60
    
    let mut score = 0;
    if res1 > 17.0 && res1 < 18.0 {
        score = score + 20;
    }
    if res2 == 60 {
        score = score + 22;
    }
    return score;
}
