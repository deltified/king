struct Point {
    x: i64,
    y: i64,
}

fn mutate_point(p: &mut Point) {
    p.x = 100;
    p.y = 200;
    return;
}

fn main() -> i64 {
    let mut p = Point { x: 10, y: 20 };
    
    p.x = 42;
    if p.x != 42 {
        return 1;
    }
    
    mutate_point(&mut p);
    if p.x != 100 {
        return 2;
    }
    if p.y != 200 {
        return 3;
    }
    
    return 42;
}
