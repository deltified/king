fn identity<T: type>(x: T) -> T {
    return x;
}

fn add_one<T: type>(x: T) -> T {
    return x + 1;
}

fn main() -> i64 {
    let a = identity<i64>(42);
    let b = add_one<i64>(9);
    
    let mut score = 0;
    if a == 42 {
        score = score + 20;
    }
    if b == 10 {
        score = score + 22;
    }
    return score;
}
