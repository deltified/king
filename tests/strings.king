import std::io;

fn main() -> i64 {
    let s1 = "Hello, World!";
    std::io::puts(s1);

    let s2 = "This\nIs\nA\nMultiline\nString";
    std::io::puts(s2);

    let s3 = "Escapes: \t \\ \" \0 hidden";
    std::io::puts(s3);
    
    let s4 = "Hello, World!";
    std::io::puts(s4);

    return 42;
}
